<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <joint name="arm_base_joint" type="fixed">
        <parent link="base_link"/>
        <child link="arm_base"/>
        <origin xyz="0 0 0.29"/>
    </joint>

    <link name="arm_base">
        <visual>
			<geometry>
				<cylinder radius = "0.15" length = "0.08"/>
			</geometry>
			<material name="black"/>
		</visual>
		<collision>
            	<geometry>
            		<cylinder radius="0.15" length="0.08"/>
        		</geometry>
        </collision>
        <inertial>
            	<mass value="1.0"/>
            	<!-- Cylinder: r=0.15, h=0.08, mass=1.0 -->
            	<!-- ixx = (1/12)*1*(3*0.15^2 + 0.08^2) = 0.006 -->
            	<!-- iyy = (1/12)*1*(3*0.15^2 + 0.08^2) = 0.006 -->
            	<!-- izz = (1/2)*1*0.15^2 = 0.011 -->
            	<inertia
            		ixx="0.006" ixy="0.0" ixz="0.0"
            		iyy="0.006" iyz="0.0"
            		izz="0.011"/>
        </inertial>
    </link>

    <joint name="arm_joint" type="revolute">
        <parent link="arm_base"/>
        <child link="arm_link"/>
        <origin xyz="0 0 0.04"/>
        <axis xyz = "0 1 0"/>
        <limit lower="-1.57" upper="1.57" effort="1000" velocity="1"/>
    </joint>

    <link name = "arm_link">
        <visual>
            <geometry>
                <box size="0.1 0.1 1"/>
            </geometry>
            <origin xyz = "0 0 0.46"/>
            <material name = "black"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.1 0.1 1"/>
            </geometry>
            <origin xyz = "0 0 0.46"/>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <!-- Box: 0.1 x 0.1 x 1, mass=1.0 -->
            <!-- ixx = (1/12)*1*(0.1^2 + 1^2) = 0.084 -->
            <!-- iyy = (1/12)*1*(0.1^2 + 1^2) = 0.084 -->
            <!-- izz = (1/12)*1*(0.1^2 + 0.1^2) = 0.0017 -->
            <inertia
                ixx="0.084" ixy="0.0" ixz="0.0"
                iyy="0.084" iyz="0.0"
                izz="0.0017"/>
        </inertial>
    </link>

    <ros2_control name="IgnitionSystem" type="system">
        <hardware>
            <plugin>ign_ros2_control/IgnitionSystem</plugin>
        </hardware>
        <joint name="arm_joint">
            <command_interface name="position">
                <param name="min">-1.57</param>
                <param name="max">1.57</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
    </ros2_control>

    <gazebo>
        <plugin filename="libign_ros2_control-system.so" name="ign_ros2_control::IgnitionROS2ControlPlugin">
            <parameters>$(find my_robot)/config/controllers.yaml</parameters>
        </plugin>
    </gazebo>
</robot>