<?xml version="1.0"?>

<robot name="my_robot">

	<material name="blue">
    		<color rgba="0 0 0.8 1"/>
  	</material>
  	
  	<material name="white">
    		<color rgba="1 1 1 1"/>
  	</material>
  	
  	<material name="black">
  		<color rgba = "0 0 0 1"/>
  	</material>
  	
  	<link name="base_dummy"/>

    	<joint name="base_dummy_joint" type="fixed">
        	<parent link="base_dummy"/>
        	<child link="base_link"/>
        	<origin xyz="0 0 0" rpy="0 0 0"/>
    	</joint>
  
	<link name = "base_link">
		<visual>
			<geometry>
				<box size="1.8 1.4 0.5"/>
			</geometry>
			<material name="blue"/>
		</visual>
		<collision>
            		<geometry>
                		<box size="1.8 1.4 0.5"/>
            		</geometry>
        	</collision>

		<inertial>
			<mass value="10.0"/>
		    	<!-- Box: 1.8 x 1.4 x 0.5, mass=10 -->
		    	<!-- ixx = (1/12)*10*(1.4^2 + 0.5^2) = 1.847 -->
		    	<!-- iyy = (1/12)*10*(1.8^2 + 0.5^2) = 2.908 -->
		    	<!-- izz = (1/12)*10*(1.8^2 + 1.4^2) = 4.333 -->
		    	<inertia
		        	ixx="1.847" ixy="0.0" ixz="0.0"
		        	iyy="2.908" iyz="0.0"
		        	izz="4.333"/>
		</inertial>
	</link>
	
	<link name = "back_left_leg">
		<visual>
			<geometry>
				<box size="0.1 0.14 0.5"/>
			</geometry>
			<material name="white"/>
			<origin xyz = "0 0 -0.125"/>
		</visual>
		
		<collision>
			<geometry>
		        	<box size="0.1 0.14 0.5"/>
		    	</geometry>
		    	<origin xyz="0 0 -0.125"/>
		</collision>

		<inertial>
		    	<mass value="0.5"/>
		    	<origin xyz="0 0 -0.125"/>
		    	<!-- Box: 0.1 x 0.14 x 0.5, mass=0.5 -->
		    	<!-- ixx = (1/12)*0.5*(0.14^2 + 0.5^2) = 0.0112 -->
		    	<!-- iyy = (1/12)*0.5*(0.1^2 + 0.5^2)  = 0.0108 -->
		   	 <!-- izz = (1/12)*0.5*(0.1^2 + 0.14^2)  = 0.0012 -->
		    	<inertia
		        	ixx="0.0112" ixy="0.0" ixz="0.0"
		        	iyy="0.0108" iyz="0.0"
		        	izz="0.0012"/>
		</inertial>
	</link>
	
	<joint name = "back_left_leg_joint" type="fixed">
		<parent link = "base_link"/>
		<child link = "back_left_leg"/>
		<origin xyz = "-0.75 -.77 -0.125"/>
		<limit lower="-1.5708" upper="1.5708" effort="10" velocity="1"/>
	</joint>
	
	<link name = "back_right_leg">
		<visual>
			<geometry>
				<box size = "0.1 0.14 0.5"/>
			</geometry>
			<material name="white"/>
			<origin xyz = "0 0 -0.125"/>
		</visual>
		<collision>
			<geometry>
		        	<box size="0.1 0.14 0.5"/>
		    	</geometry>
		    	<origin xyz="0 0 -0.125"/>
		</collision>

		<inertial>
		    	<mass value="0.5"/>
		    	<origin xyz="0 0 -0.125"/>
		    	<!-- Box: 0.1 x 0.14 x 0.5, mass=0.5 -->
		    	<!-- ixx = (1/12)*0.5*(0.14^2 + 0.5^2) = 0.0112 -->
		    	<!-- iyy = (1/12)*0.5*(0.1^2 + 0.5^2)  = 0.0108 -->
		   	 <!-- izz = (1/12)*0.5*(0.1^2 + 0.14^2)  = 0.0012 -->
		    	<inertia
		        	ixx="0.0112" ixy="0.0" ixz="0.0"
		        	iyy="0.0108" iyz="0.0"
		        	izz="0.0012"/>
		</inertial>
	</link>
	
	<joint name = "back_right_leg_joint" type = "fixed">
		<parent link = "base_link"/>
		<child link = "back_right_leg"/>
		<origin xyz = "-0.75 0.77 -0.125"/>
		<limit lower="-1.5708" upper="1.5708" effort="10" velocity="1"/>
	</joint>
	
	<link name = "front_left_leg">
		<visual>
			<geometry>
				<box size="0.1 0.14 0.5"/>
			</geometry>
			<material name="white"/>
			<origin xyz = "0 0 -0.125"/>
		</visual>
		<collision>
			<geometry>
		        	<box size="0.1 0.14 0.5"/>
		    	</geometry>
		    	<origin xyz="0 0 -0.125"/>
		</collision>

		<inertial>
		    	<mass value="0.5"/>
		    	<origin xyz="0 0 -0.125"/>
		    	<!-- Box: 0.1 x 0.14 x 0.5, mass=0.5 -->
		    	<!-- ixx = (1/12)*0.5*(0.14^2 + 0.5^2) = 0.0112 -->
		    	<!-- iyy = (1/12)*0.5*(0.1^2 + 0.5^2)  = 0.0108 -->
		   	 <!-- izz = (1/12)*0.5*(0.1^2 + 0.14^2)  = 0.0012 -->
		    	<inertia
		        	ixx="0.0112" ixy="0.0" ixz="0.0"
		        	iyy="0.0108" iyz="0.0"
		        	izz="0.0012"/>
		</inertial>
	</link>
	
	<joint name = "front_left_leg_joint" type="fixed">
		<parent link = "base_link"/>
		<child link = "front_left_leg"/>
		<origin xyz = "0.75 -.77 -0.125"/>
		<limit lower="-1.5708" upper="1.5708" effort="10" velocity="1"/>
	</joint>
	
	<link name = "front_right_leg">
		<visual>
			<geometry>
				<box size = "0.1 0.14 0.5"/>
			</geometry>
			<material name="white"/>
			<origin xyz = "0 0 -0.125"/>
		</visual>
		<collision>
			<geometry>
		        	<box size="0.1 0.14 0.5"/>
		    	</geometry>
		    	<origin xyz="0 0 -0.125"/>
		</collision>

		<inertial>
		    	<mass value="0.5"/>
		    	<origin xyz="0 0 -0.125"/>
		    	<!-- Box: 0.1 x 0.14 x 0.5, mass=0.5 -->
		    	<!-- ixx = (1/12)*0.5*(0.14^2 + 0.5^2) = 0.0112 -->
		    	<!-- iyy = (1/12)*0.5*(0.1^2 + 0.5^2)  = 0.0108 -->
		   	 <!-- izz = (1/12)*0.5*(0.1^2 + 0.14^2)  = 0.0012 -->
		    	<inertia
		        	ixx="0.0112" ixy="0.0" ixz="0.0"
		        	iyy="0.0108" iyz="0.0"
		        	izz="0.0012"/>
		</inertial>
	</link>
	
	<joint name = "front_right_leg_joint" type = "fixed">
		<parent link = "base_link"/>
		<child link = "front_right_leg"/>
		<origin xyz = "0.75 0.77 -0.125"/>
		<limit lower="-1.5708" upper="1.5708" effort="10" velocity="1"/>
	</joint>
	
	<link name = "left_back_wheel">
		<visual>
			<geometry>
				<cylinder radius = "0.15" length = "0.08"/>
			</geometry>
			<material name="black"/>
			<origin rpy = "1.5708 0 0"/>
		</visual>
		<collision>
            		<geometry>
                		<cylinder radius="0.15" length="0.08"/>
            		</geometry>
           	 	<origin rpy="1.5708 0 0"/>
        	</collision>

        	<inertial>
            		<mass value="1.0"/>
            		<!-- Cylinder: r=0.15, h=0.08, mass=1.0 -->
            		<!-- ixx = (1/12)*1*(3*0.15^2 + 0.08^2) = 0.006 -->
            		<!-- iyy = (1/12)*1*(3*0.15^2 + 0.08^2) = 0.006 -->
            		<!-- izz = (1/2)*1*0.15^2 = 0.011 -->
            		<inertia
                		ixx="0.006" ixy="0.0" ixz="0.0"
                		iyy="0.006" iyz="0.0"
                		izz="0.011"/>
        	</inertial>
	</link>
	
	<joint name = "left_back_wheel_joint" type = "continuous">
		<parent link = "back_left_leg"/>
		<child link = "left_back_wheel"/>
		<axis xyz = "0 1 0"/>
		<origin xyz = "0 0 -0.4"/>
	</joint>
	
	<link name = "right_back_wheel">
		<visual>
			<geometry>
				<cylinder radius = "0.15" length = "0.08"/>
			</geometry>
			<material name="black"/>
			<origin rpy = "1.5708 0 0"/>
		</visual>
		
		<collision>
            		<geometry>
                		<cylinder radius="0.15" length="0.08"/>
            		</geometry>
           	 	<origin rpy="1.5708 0 0"/>
        	</collision>

        	<inertial>
            		<mass value="1.0"/>
            		<!-- Cylinder: r=0.15, h=0.08, mass=1.0 -->
            		<!-- ixx = (1/12)*1*(3*0.15^2 + 0.08^2) = 0.006 -->
            		<!-- iyy = (1/12)*1*(3*0.15^2 + 0.08^2) = 0.006 -->
            		<!-- izz = (1/2)*1*0.15^2 = 0.011 -->
            		<inertia
                		ixx="0.006" ixy="0.0" ixz="0.0"
                		iyy="0.006" iyz="0.0"
                		izz="0.011"/>
        	</inertial>
	</link>
	
	<joint name = "right_back_wheel_joint" type = "continuous">
		<parent link = "back_right_leg"/>
		<child link = "right_back_wheel"/>
		<axis xyz = "0 1 0"/>
		<origin xyz = "0 0 -0.4"/>
	</joint>
	
	<link name = "left_front_wheel">
		<visual>
			<geometry>
				<cylinder radius = "0.15" length = "0.08"/>
			</geometry>
			<material name="black"/>
			<origin rpy = "1.5708 0 0"/>
		</visual>
		
		<collision>
            		<geometry>
                		<cylinder radius="0.15" length="0.08"/>
            		</geometry>
           	 	<origin rpy="1.5708 0 0"/>
        	</collision>

        	<inertial>
            		<mass value="1.0"/>
            		<!-- Cylinder: r=0.15, h=0.08, mass=1.0 -->
            		<!-- ixx = (1/12)*1*(3*0.15^2 + 0.08^2) = 0.006 -->
            		<!-- iyy = (1/12)*1*(3*0.15^2 + 0.08^2) = 0.006 -->
            		<!-- izz = (1/2)*1*0.15^2 = 0.011 -->
            		<inertia
                		ixx="0.006" ixy="0.0" ixz="0.0"
                		iyy="0.006" iyz="0.0"
                		izz="0.011"/>
        	</inertial>
	</link>
	
	<joint name = "left_front_wheel_joint" type = "continuous">
		<parent link = "front_left_leg"/>
		<child link = "left_front_wheel"/>
		<axis xyz = "0 1 0"/>
		<origin xyz = "0 0 -0.4"/>
	</joint>
	
	<link name = "right_front_wheel">
		<visual>
			<geometry>
				<cylinder radius = "0.15" length = "0.08"/>
			</geometry>
			<material name="black"/>
			<origin rpy = "1.5708 0 0"/>
		</visual>
		<collision>
            		<geometry>
                		<cylinder radius="0.15" length="0.08"/>
            		</geometry>
           	 	<origin rpy="1.5708 0 0"/>
        	</collision>

        	<inertial>
            		<mass value="1.0"/>
            		<!-- Cylinder: r=0.15, h=0.08, mass=1.0 -->
            		<!-- ixx = (1/12)*1*(3*0.15^2 + 0.08^2) = 0.006 -->
            		<!-- iyy = (1/12)*1*(3*0.15^2 + 0.08^2) = 0.006 -->
            		<!-- izz = (1/2)*1*0.15^2 = 0.011 -->
            		<inertia
                		ixx="0.006" ixy="0.0" ixz="0.0"
                		iyy="0.006" iyz="0.0"
                		izz="0.011"/>
        	</inertial>
	</link>
	
	<joint name = "right_front_wheel_joint" type = "continuous">
		<parent link = "front_right_leg"/>
		<child link = "right_front_wheel"/>
		<axis xyz = "0 1 0"/>
		<origin xyz = "0 0 -0.4"/>
	</joint>
		
	<!-- Diff Drive Plugin for Gazebo Ignition -->
	<gazebo>
    		<plugin
        		filename="libignition-gazebo-diff-drive-system.so"
        		name="ignition::gazebo::systems::DiffDrive">

        	<!-- Left wheels -->
        	<left_joint>left_back_wheel_joint</left_joint>
        	<left_joint>left_front_wheel_joint</left_joint>

        	<!-- Right wheels -->
        	<right_joint>right_back_wheel_joint</right_joint>
        	<right_joint>right_front_wheel_joint</right_joint>

        	<!-- Wheel properties -->
        	<wheel_separation>1.54</wheel_separation>
        	<wheel_radius>0.15</wheel_radius>

        	<!-- Gazebo topic to listen for commands -->
        	<topic>cmd_vel</topic>

    		</plugin>
	</gazebo>
	
	<!-- Wheel Friction -->
	<gazebo reference="left_back_wheel">
   		<mu1>1.0</mu1>
    		<mu2>1.0</mu2>
	</gazebo>

	<gazebo reference="right_back_wheel">
   	 	<mu1>1.0</mu1>
    		<mu2>1.0</mu2>
	</gazebo>

	<gazebo reference="left_front_wheel">
    		<mu1>1.0</mu1>
    		<mu2>1.0</mu2>
	</gazebo>

	<gazebo reference="right_front_wheel">
    		<mu1>1.0</mu1>
    		<mu2>1.0</mu2>
	</gazebo>
	
	    <!-- Joint State Publisher Plugin -->
    	<gazebo>
        	<plugin
            	filename="libignition-gazebo-joint-state-publisher-system.so"
            	name="ignition::gazebo::systems::JointStatePublisher">
        	</plugin>
    	</gazebo>
	
</robot>
